# Godot 4+ specific ignores
.godot/

# Exported builds
/android/
/exports/
*.apk
*.aab
*.exe
*.x86_64
*.pck

# Build outputs from CI (Godot --export-pack writes here)
/build/

# Xcode build outputs inside the committed iOS shell
/ios/build/
/ios/DerivedData/
# The runtime PCK is regenerated on every CI run; never commit it.
/ios/TheMotorcycleGame/TheMotorcycleGame.pck

# Godot import backups
*.import.bak

# Mono/.NET (if using C#)
.mono/
data_*/
mono_crash.*.json

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor files
.vscode/
*.swp
*.swo
*~
